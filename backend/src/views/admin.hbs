<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-6 text-gray-200">
        Prometheus Mocker
    </h1>
    <div class="bg-white rounded-xl shadow p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4">Create Metric</h2>
        <form method="POST" action="/admin" class="grid grid-cols-2 gap-4">
            <div>
                <label class="text-sm text-gray-600">Name</label>
                <input name="name"
                       class="w-full border rounded-lg p-2 mt-1 focus:ring focus:ring-blue-200"/>
            </div>
            <div>
                <label class="text-sm text-gray-600">Type</label>
                <select name="type"
                        class="w-full border rounded-lg p-2 mt-1">
                    <option value="gauge">Gauge</option>
                    <option value="counter">Counter</option>
                </select>
            </div>
            <div>
                <label class="text-sm text-gray-600">Help</label>
                <input name="help"
                       class="w-full border rounded-lg p-2 mt-1"/>
            </div>
            <div>
                <label class="text-sm text-gray-600">Value</label>
                <input name="value"
                       class="w-full border rounded-lg p-2 mt-1"/>
            </div>
            <div class="col-span-2">
                <button
                        class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                    Create
                </button>
            </div>
        </form>
    </div>
    <div class="bg-white rounded-xl shadow p-6">
        <h2 class="text-xl font-semibold mb-4">
            Existing Metrics
        </h2>
        <div class="space-y-4">
            {{#each metrics}}
                <div class="flex items-center justify-between border rounded-lg p-4">
                    <div>
                        <div class="font-medium text-gray-800">
                            {{this.name}} ({{this.help}})
                        </div>
                        <div class="text-sm text-gray-500">
                            {{this.type}}
                        </div>
                    </div>
                    <form method="POST"
                          action="/admin/update"
                          class="flex gap-2 items-center">
                        <input type="hidden"
                               name="name"
                               value="{{this.name}}"/>
                        <input name="value"
                               value="{{this.value}}"
                               class="border rounded-lg p-2 w-24"/>
                        <button
                                class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700">
                            Update
                        </button>
                    </form>
                    <form method="POST" action="/admin/delete" onsubmit="return confirm('Biztosan törlöd a(z) {{this.name}} metrikát?')">
                        <input type="hidden" name="name" value="{{this.name}}"/>
                        <button class="text-red-500 hover:text-red-700 p-2 transition" title="Delete Metric">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </form>
                </div>
            {{/each}}
        </div>
    </div>
</div>
